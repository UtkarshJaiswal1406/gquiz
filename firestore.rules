rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isValidSession(data) {
      return data.keys().hasOnly(['status', 'startTime', 'endTime'])
        && data.status in ['waiting', 'active', 'ended']
        && (data.startTime is int || data.startTime == null)
        && (data.endTime is int || data.endTime == null);
    }

    function isValidResult(data) {
      return data.keys().hasOnly(['name', 'score', 'timeTaken', 'createdAt'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 40
        && data.score is int
        && data.timeTaken is int
        && data.timeTaken >= 0
        && data.createdAt is int;
    }

    match /quizSessions/{sessionId} {
      allow read: if true;
      allow write: if isValidSession(request.resource.data);
    }

    match /quizResults/{resultId} {
      allow read: if true;
      allow create: if isValidResult(request.resource.data);
      allow update: if false;
      allow delete: if true;
    }
  }
}